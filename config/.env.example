# Environment Variables for Local Development
# Copy this file to .env and add your actual API keys

# OpenAI API Key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Flask Configuration
SECRET_KEY=your_secret_key_here
DEBUG=True

# TTL Configuration (in seconds)
SESSION_LIFETIME=2592000  # 30 days (default: 2592000)
# Options: 86400=24h, 604800=7d, 2592000=30d, 31536000=1y

# ── Azure AD Authentication ───────────────────────────────────────────────────
# App registration → Overview
AZURE_AD_CLIENT_ID=your-client-id-here
# App registration → Certificates & secrets → Client secret value
AZURE_AD_CLIENT_SECRET=your-client-secret-here
# Azure AD → Overview → Tenant ID
AZURE_AD_TENANT_ID=your-tenant-id-here
# Must match a redirect URI registered under App registration → Authentication → Web
# Local:      http://localhost:5001/auth/callback
# Production: https://your-app.azurewebsites.net/auth/callback
AZURE_AD_REDIRECT_URI=http://localhost:5001/auth/callback
